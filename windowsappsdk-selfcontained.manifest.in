<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<assembly manifestVersion="1.0"
          xmlns:asmv3="urn:schemas-microsoft-com:asm.v3"
          xmlns:winrtv1="urn:schemas-microsoft-com:winrt.v1"
          xmlns="urn:schemas-microsoft-com:asm.v1">
  <assemblyIdentity
      name="@PROJECT_NAME@"
      version="1.0.0.0"
      processorArchitecture="*"
      type="win32" />

  <asmv3:file name="CoreMessagingXP.dll">
    <winrtv1:activatableClass name="Microsoft.UI.Dispatching.DispatcherExitDeferral" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.Dispatching.DispatcherQueue" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.Dispatching.DispatcherQueueController" threadingModel="both" />
  </asmv3:file>

  <asmv3:file name="Microsoft.UI.dll">
    <winrtv1:activatableClass name="Microsoft.UI.Colors" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.ColorHelper" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.System.ThemeSettings" threadingModel="both" />
  </asmv3:file>

  <asmv3:file name="Microsoft.UI.Windowing.dll">
    <winrtv1:activatableClass name="Microsoft.UI.Windowing.AppWindow" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.Windowing.AppWindowPlacementDetails" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.Windowing.AppWindowPresenter" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.Windowing.CompactOverlayPresenter" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.Windowing.DisplayArea" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.Windowing.FullScreenPresenter" threadingModel="both" />
    <winrtv1:activatableClass name="Microsoft.UI.Windowing.OverlappedPresenter" threadingModel="both" />
  </asmv3:file>

  <asmv3:file name="Microsoft.UI.Windowing.Core.dll">
    <winrtv1:activatableClass name="Microsoft.UI.Windowing.AppWindowTitleBar" threadingModel="both" />
  </asmv3:file>
</assembly>
